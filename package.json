{
  "name": "solana-agent-wallet",
  "version": "0.1.0",
  "type": "module",
  "description": "Solana devnet agentic wallet CLI — create wallets, sign transactions, transfer SOL/SPL tokens, and run autonomous agent flows. Built for AI agents.",
  "bin": {
    "agent-wallet": "dist/index.js"
  },
  "files": [
    "dist",
    "SKILLS.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "cli": "node dist/index.js",
    "demo": "node dist/index.js demo:run --rounds 2",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "solana",
    "wallet",
    "agent",
    "ai",
    "devnet",
    "cli",
    "spl-token",
    "autonomous"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "commander": "^14.0.1",
    "dotenv": "^17.2.3",
    "groq-sdk": "^0.37.0",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "openai": "^6.27.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}
