    "@solana/web3.js": "^1.98.4",
    "commander": "^14.0.1",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}
