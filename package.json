{
  "name": "prototype-ai-agent-wallet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Solana devnet agentic wallet CLI with encrypted key storage, autonomous flows, and protocol adapters.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
